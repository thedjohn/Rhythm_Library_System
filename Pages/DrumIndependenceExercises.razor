                <div class="di-related-card" @onclick='() => Nav.NavigateTo("/three-camps-drum-exercise")'><h3>Three Camps Drum Exercise →</h3><p>Apply independence patterns to the classic Three Camps sequence.</p></div>
                <div class="di-related-card" @onclick='() => Nav.NavigateTo("/learn-drum-notation")'><h3>Learn Drum Notation →</h3><p>Read the notation in the app — a beginner-friendly guide.</p></div>
            </div>
        </div>
    </div>

